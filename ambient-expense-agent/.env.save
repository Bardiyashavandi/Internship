# =====================================================================
# Local Authentication Environment Configuration
# =====================================================================
# Choose ONE of the authentication methods below by filling out the
# corresponding variables.
# =====================================================================

# --- METHOD 1: Google AI Studio (Gemini Developer API Key) ---s# Obtain your key from: https://aistudio.google.com/
s# Uncomment and set this if you want to use the developer API directly.
 GEMINI_API_KEY=your_google_ai_studio_api_key_here

# --- METHOD 2: Google Cloud / Vertex AI (Google Cloud Project) ---
# Set the following variables to route calls through Google Cloud (Vertex AI).
# Make sure to run `gcloud auth application-default login` in your terminal
# to set up Application Default Credentials (ADC) for local development.
GOOGLE_CLOUD_PROJECT=your_gcp_project_id_here
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VEREX_AI=False
